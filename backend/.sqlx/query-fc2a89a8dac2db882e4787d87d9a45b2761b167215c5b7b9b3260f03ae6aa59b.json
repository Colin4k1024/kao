{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT DISTINCT\n                sm.id,\n                sm.parent_id,\n                sm.name,\n                sm.menu_type,\n                sm.route_path,\n                sm.component,\n                sm.permission,\n                sm.icon,\n                sm.sort_order,\n                sm.visible\n            FROM sys_menus sm\n            JOIN sys_role_menus srm ON sm.id = srm.menu_id\n            JOIN sys_user_roles sur ON srm.role_id = sur.role_id\n            WHERE sur.user_id = $1 AND sm.status = 'ACTIVE'\n            ORDER BY sm.parent_id, sm.sort_order\n            ",
