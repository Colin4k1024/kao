  "query": "\n        UPDATE sys_roles \n        SET \n            name = COALESCE($2, name),\n            description = COALESCE($3, description),\n            data_scope = COALESCE($4, data_scope),\n            status = COALESCE($5, status),\n            updated_at = NOW()\n        WHERE id = $1\n        RETURNING \n            id, code, name, description, data_scope, status, \n            is_system, created_at, updated_at\n        ",
