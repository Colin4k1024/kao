{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id,\n            username,\n            display_name,\n            password_hash,\n            email,\n            dept_id,\n            avatar_url,\n            status,\n            is_super_admin\n        FROM sys_users \n        WHERE username = $1 AND status = 'ACTIVE' AND (deleted_at IS NULL OR deleted_at > NOW())\n        ",
