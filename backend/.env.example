# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgres://postgres:password@localhost:5432/kao_db
DB_PASSWORD=your-password

# Connection Pool Settings
# Maximum number of connections in the pool
DATABASE_MAX_CONNECTIONS=20
# Minimum number of connections to maintain in the pool
DATABASE_MIN_CONNECTIONS=5
# Time in seconds before a connection times out during establishment
DATABASE_CONNECT_TIMEOUT=10
# Time in seconds before an idle connection is closed
DATABASE_IDLE_TIMEOUT=300

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600
REDIS_CONNECTION_POOL_SIZE=10

# =============================================================================
# JWT Configuration
# IMPORTANT: JWT_SECRET must be at least 32 characters in production!
# Generate with: openssl rand -base64 32
# =============================================================================
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES_IN=3600
JWT_REFRESH_TOKEN_EXPIRES_IN=604800

# =============================================================================
# Application Configuration
# =============================================================================
APP_HOST=0.0.0.0
APP_PORT=8080
RUST_LOG=info

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_MAX_AGE=3600
